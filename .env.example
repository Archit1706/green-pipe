# GitLab Configuration
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your_gitlab_personal_access_token
# Webhook secret — must match the "Secret token" set in GitLab → Settings → Webhooks.
# Leave blank to skip header verification (development only).
GITLAB_WEBHOOK_SECRET=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/greenpipe

# Carbon Aware SDK (self-hosted or cloud endpoint)
# Docs: https://github.com/Green-Software-Foundation/carbon-aware-sdk
CARBON_AWARE_SDK_URL=http://localhost:5073
# Fallback API keys (optional)
ELECTRICITY_MAPS_API_KEY=
WATTTIME_USER=
WATTTIME_PASSWORD=

# Auto-deferral policy
# Mode: "recommend-only" (default) | "approval-required" | "auto-execute"
GREENPIPE_DEFER_MODE=recommend-only
# Minimum carbon savings (%) to trigger deferral action (default: 20)
GREENPIPE_MIN_SAVINGS_PCT=20.0
# Maximum hours a pipeline may be deferred (default: 24)
GREENPIPE_MAX_DELAY_HOURS=24
# Comma-separated branch patterns to never defer (supports trailing * glob)
GREENPIPE_PROTECTED_BRANCHES=main,master,release*
# Comma-separated environment names to never defer
GREENPIPE_PROTECTED_ENVS=production,staging

# Application
APP_ENV=development
LOG_LEVEL=INFO
