# GitLab Configuration
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your_gitlab_personal_access_token

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/greenpipe

# Carbon Aware SDK (self-hosted or cloud endpoint)
# Docs: https://github.com/Green-Software-Foundation/carbon-aware-sdk
CARBON_AWARE_SDK_URL=http://localhost:5073
# Fallback API keys (optional)
ELECTRICITY_MAPS_API_KEY=
WATTTIME_USER=
WATTTIME_PASSWORD=

# Application
APP_ENV=development
LOG_LEVEL=INFO
